---
---

<div 
  id="cookie-banner" 
  class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-xl bg-gemma-green/95 backdrop-blur-md border border-gemma-sand/20 p-6 md:p-8 z-[200] shadow-2xl transition-all duration-700 opacity-0 translate-y-10 hidden"
>
  <div class="flex flex-col md:flex-row items-center gap-6">
    <div class="flex-grow text-center md:text-left">
      <h3 class="font-serif text-lg text-gemma-sand mb-2 tracking-wide uppercase">Privacidade & Cookies</h3>
      <p class="text-gemma-sand/80 text-[11px] leading-relaxed font-light font-sans">
        Utilizamos cookies para personalizar sua experiência. Ao continuar navegando, você concorda com nossa 
        <a href="/politica-de-privacidade" class="underline hover:text-white transition-colors">política de privacidade</a>.
      </p>
    </div>
    <div class="flex-shrink-0">
      <button 
        id="accept-cookies" 
        class="bg-gemma-sand text-gemma-green px-8 py-3 uppercase tracking-[0.2em] text-[10px] font-semibold hover:bg-white transition-all duration-500 shadow-lg"
      >
        Aceitar
      </button>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const cookieConsent = localStorage.getItem('gemma-cookie-consent');

    if (!cookieConsent) {
      // Pequeno delay para não carregar imediatamente com o Hero
      setTimeout(() => {
        banner.classList.remove('hidden');
        // Trigger reflow
        banner.offsetHeight; 
        banner.classList.add('opacity-100', 'translate-y-0');
        banner.classList.remove('opacity-0', 'translate-y-10');
      }, 2000);
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('gemma-cookie-consent', 'true');
      banner.classList.add('opacity-0', 'translate-y-10');
      banner.classList.remove('opacity-100', 'translate-y-0');
      setTimeout(() => {
        banner.classList.add('hidden');
      }, 700);
    });
  });
</script>
