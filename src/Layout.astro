---
import CookieBanner from './CookieBanner.astro';

interface Props {
	title: string;
}
const { title } = Astro.props;
const siteUrl = "https://gemmaboutique.com.br";
const description = "Aluguel de acessórios de luxo para noivas em Salvador, BA. Curadoria exclusiva de grinaldas, clutches e terços que contam histórias. Agende seu atendimento.";
const ogImage = siteUrl + "/logo-gemma.jpg";
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<title>{title.includes('Gemma') ? title : `${title} | Gemma Boutique - Aluguel de Acessórios de Noiva`}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={siteUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />

		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		
		<!-- Preconnect & Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

		<!-- JSON-LD Structured Data Avançado -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "ClothingStore",
				"name": "Gemma Boutique",
				"image": "https://gemmaboutique.com.br/logo-gemma.jpg",
				"description": "Aluguel de acessórios de luxo para noivas e ocasiões especiais em Salvador, BA.",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Apipema Center",
					"addressLocality": "Salvador",
					"addressRegion": "BA",
					"postalCode": "40169610",
					"addressCountry": "BR"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": -13.0075,
					"longitude": -38.5085
				},
				"url": "https://gemmaboutique.com.br",
				"telephone": "+5571996313232",
				"priceRange": "$$$",
				"openingHoursSpecification": [
					{
						"@type": "OpeningHoursSpecification",
						"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
						"opens": "09:00",
						"closes": "18:00"
					}
				],
				"sameAs": [
					"https://www.instagram.com/gemma.loc/",
					"https://www.tiktok.com/@gemma.loc"
				]
			}
		</script>

		<!-- Breadcrumbs Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				"itemListElement": [
					{
						"@type": "ListItem",
						"position": 1,
						"name": "Home",
						"item": "https://gemmaboutique.com.br"
					},
					{
						"@type": "ListItem",
						"position": 2,
						"name": "Política de Privacidade",
						"item": "https://gemmaboutique.com.br/politica-de-privacidade"
					}
				]
			}
		</script>
	</head>
	<body id="top" class="bg-gemma-green text-gemma-sand font-sans antialiased selection:bg-gemma-sand selection:text-gemma-green min-h-screen flex flex-col">
		<slot />
		<CookieBanner />

		<style is:global>
			html {
				scroll-behavior: auto !important;
			}
		</style>

		<script src="https://unpkg.com/lenis@1.1.9/dist/lenis.min.js"></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const lenis = new Lenis({
					duration: 1.8,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					smoothWheel: true,
					wheelMultiplier: 1.0,
					lerp: 0.08,
				});

				function raf(time) {
					lenis.raf(time);
					requestAnimationFrame(raf);
				}

				requestAnimationFrame(raf);
			});
		</script>
	</body>
</html>
