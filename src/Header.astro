---
import Logo from './Logo.astro';

const phone = "+55 71 99631-3232";
---

<header 
  id="main-header"
  class="fixed top-0 left-0 w-full z-[100] transition-all duration-700 ease-in-out py-4 sm:py-6 px-4 sm:px-12 bg-transparent"
>
  <div class="max-w-7xl mx-auto grid grid-cols-2 sm:grid-cols-3 items-center">
    <div class="flex justify-start">
      <a href="/" class="inline-block" id="header-logo-container">
        <Logo className="text-[11px] sm:text-lg md:text-xl" id="header-logo" />
      </a>
    </div>

    <div class="hidden sm:flex items-center justify-center">
      <div class="flex items-center gap-5 opacity-70">

        <a href="https://www.tiktok.com/@gemma.loc" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity" aria-label="TikTok">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 448 512">
            <path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/gemma.loc/" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity" aria-label="Instagram">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="https://wa.me/5571996313232" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity" aria-label="WhatsApp">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="flex justify-end items-center">
      <a 
        href={`tel:${phone.replace(/[^\d+]/g, '')}`} 
        class="flex items-center gap-2 text-sm sm:text-base uppercase tracking-[0.2em] font-light opacity-80 hover:opacity-100 transition-opacity whitespace-nowrap"
      >
        <svg class="w-4 h-4 opacity-60" fill="currentColor" viewBox="0 0 512 512">
            <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
        </svg>
        <span>{phone}</span>
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  const logoContainer = document.getElementById('header-logo-container');
  
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-gemma-green/80', 'backdrop-blur-md', 'py-3', 'shadow-2xl');
      header.classList.remove('bg-transparent', 'py-4', 'sm:py-6');
      if (logoContainer) {
        logoContainer.style.transform = 'scale(0.85)';
        logoContainer.style.opacity = '0.9';
      }
    } else {
      header.classList.remove('bg-gemma-green/80', 'backdrop-blur-md', 'py-3', 'shadow-2xl');
      header.classList.add('bg-transparent', 'py-4', 'sm:py-6');
      if (logoContainer) {
        logoContainer.style.transform = 'scale(1)';
        logoContainer.style.opacity = '1';
      }
    }
  };

  window.addEventListener('scroll', handleScroll);
  handleScroll();
</script>

<style>
  #header-logo-container {
    transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: left center;
  }
</style>
