---
import Logo from './Logo.astro';
---

<footer
  class="mt-auto pt-16 pb-10 px-6 border-t border-gemma-sand/10 bg-gemma-green"
>
  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    <!-- Coluna de Informações -->
    <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
      <a href="/" class="mb-6 block">
        <img
          src="/gemma-footer.png"
          alt="Gemma Boutique Logo"
          class="w-48 sm:w-56 object-contain"
        />
      </a>

      <p class="text-[10px] uppercase tracking-[0.3em] font-light opacity-60 mb-8">
        Curadoria de luxo em acessórios
      </p>

      <div class="flex flex-wrap justify-center lg:justify-start items-center gap-6 mb-8">
        <a
          href="https://instagram.com/gemma.loc"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-[0.2em] hover:opacity-100 opacity-70 transition-all flex items-center space-x-3"
          aria-label="Instagram da Gemma Boutique"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
          <span>Instagram</span>
        </a>

        <a
          href="tel:+5571996313232"
          class="text-xs uppercase tracking-[0.2em] hover:opacity-100 opacity-70 transition-all flex items-center space-x-3"
          aria-label="Telefone da Gemma Boutique"
        >
          <svg class="w-4 h-4 opacity-70" fill="currentColor" viewBox="0 0 512 512">
            <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
          </svg>
          <span>71 99631-3232</span>
        </a>
      </div>

      <p class="text-[10px] uppercase tracking-widest font-light opacity-50 mb-4 leading-relaxed max-w-sm">
        Rua Professor Sabino Silva, 836 - Piso L2 - Apipema Center Salvador - Bahia - CEP.: 40.169-610.
      </p>
    </div>

    <!-- Coluna do Mapa -->
    <div class="w-full group">
      <a 
        href="https://www.google.com/maps/search/?api=1&query=Apipema+Center+Salvador+BA" 
        target="_blank" 
        rel="noopener noreferrer"
        class="block w-full h-48 sm:h-56 overflow-hidden opacity-60 group-hover:opacity-100 transition-all duration-1000 relative border border-gemma-sand/10 rounded-sm"
        aria-label="Abrir rota no Google Maps"
      >
        <div class="absolute inset-0 bg-gemma-green/40 group-hover:bg-transparent transition-all duration-1000 z-10 mix-blend-multiply"></div>
        <img 
          src="/gemma-map.png" 
          alt="Mapa de Localização da Gemma Boutique no Apipema Center" 
          class="w-full h-full object-cover transform scale-105 group-hover:scale-100 transition-transform duration-[1.5s] ease-out"
          loading="lazy"
        />

        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-1000 z-20 pointer-events-none">
          <span class="text-gemma-sand text-[9px] uppercase tracking-[0.4em] font-light flex items-center gap-3 bg-gemma-green/90 px-6 py-3 rounded-full backdrop-blur-sm border border-gemma-sand/20">
            Veja como chegar 
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </span>
        </div>
      </a>
    </div>
  </div>

  <!-- Copyright & Credits -->
  <div class="mt-16 pt-8 border-t border-gemma-sand/5 text-center">
    <p class="text-[9px] opacity-40 uppercase tracking-[0.2em] font-light mb-2">
      <a href="/politica-de-privacidade" class="hover:text-gemma-sand transition-colors">Política de Privacidade</a>
    </p>
    <p class="text-[9px] opacity-40 uppercase tracking-[0.2em] font-light max-w-3xl mx-auto leading-relaxed px-4">
      &copy; {new Date().getFullYear()} Gemma Boutique • Todos os direitos reservados | Site desenvolvido por <a href="https://criade.art.br/" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 hover:text-white transition-all font-medium">Criade Comunicação e Design</a>
    </p>
  </div>
</footer>
