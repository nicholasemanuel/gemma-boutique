---
interface Props {
  className?: string;
  variant?: 'light' | 'dark';
  id?: string;
}

const { className = "text-2xl", variant = 'light', id } = Astro.props;
---

<div 
  id={id}
  class={`font-serif tracking-[0.2em] sm:tracking-[0.3em] uppercase whitespace-nowrap transition-all duration-700 ${className} ${variant === 'light' ? 'text-gemma-sand' : 'text-gemma-green'}`}
>
  Gemma Boutique
</div>

<style>
  div {
    font-weight: 300;
    text-shadow: 0 0 20px rgba(229, 221, 200, 0.2);
  }
</style>
